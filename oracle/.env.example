# ═══════════════════════════════════════════════════════════════════════════
#                     MOON FORGE ORACLE CONFIGURATION v12.0
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# NEVER COMMIT .env TO GIT — add it to .gitignore!

# ─────────────────────────────────────────────────────────────────────────────
# EVM RPC ENDPOINTS — for reading MissionStarted burn events
# Use a reliable provider (Alchemy, Infura, QuickNode, etc.)
# ─────────────────────────────────────────────────────────────────────────────

# Phase 1 (Day 0) — always required
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY
OP_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Phase 2 (Day 13) — add before Day 13
BSC_RPC_URL=https://bsc-dataseed.binance.org

# Phase 3 (Day 26) — add before Day 26
POLYGON_RPC_URL=https://polygon-rpc.com
AVAX_RPC_URL=https://api.avax.network/ext/bc/C/rpc

# Phase 4 (Day 39) — add before Day 39
BASE_RPC_URL=https://mainnet.base.org
PULSE_RPC_URL=https://rpc.pulsechain.com

# ─────────────────────────────────────────────────────────────────────────────
# EVM PORTAL ADDRESSES — MoonForgePortal.sol on each chain (fill after deploy)
# These are standard 0x EVM addresses.
# ─────────────────────────────────────────────────────────────────────────────

ETH_PORTAL_ADDRESS=0x0000000000000000000000000000000000000000
OP_PORTAL_ADDRESS=0x0000000000000000000000000000000000000000

# Add when deploying Phase 2 / Phase 3 / Phase 4 portals:
# BSC_PORTAL_ADDRESS=0x0000000000000000000000000000000000000000
# POLYGON_PORTAL_ADDRESS=0x0000000000000000000000000000000000000000
# AVAX_PORTAL_ADDRESS=0x0000000000000000000000000000000000000000
# BASE_PORTAL_ADDRESS=0x0000000000000000000000000000000000000000
# PULSE_PORTAL_ADDRESS=0x0000000000000000000000000000000000000000

# ─────────────────────────────────────────────────────────────────────────────
# X1 SVM — for publishing Merkle roots to the MoonForge Anchor program
#
# X1 runs the Solana Virtual Machine (SVM), NOT EVM.
# All X1 addresses are Base58 Solana public keys, NOT 0x EVM addresses.
# Use @solana/web3.js (not ethers.js) for X1 interactions.
#
# X1 RPC: https://rpc.mainnet.x1.xyz (confirm from https://docs.x1.xyz)
# X1 Chain ID: 202401 (for frontend wallet connection — confirm before deploy)
# ─────────────────────────────────────────────────────────────────────────────

# X1 SVM RPC endpoint
X1_RPC_URL=https://rpc.mainnet.x1.xyz

# MoonForge Anchor program ID on X1 (Base58) — DEPLOYED
X1_PROGRAM_ID=57UE1U1t23ztg2noLp8pcpGW1B1Xw25rLH6ra9Mchea9

# MoonCommander NFT Anchor program ID on X1 (Base58) — TBD after Rust/Anchor deploy
X1_COMMANDER_PROGRAM_ID=

# Oracle Solana keypair — the private key that signs epoch publications on X1.
# The PUBLIC address of this keypair must equal ORACLE_WALLET in the root .env
# (set at contract deploy time — immutable after renounceOwnership()).
#
# Supported formats:
#   JSON array: [1,2,...,64]   ← solana-keygen new --outfile keypair.json → cat keypair.json
#   Base58 string              ← Phantom / Backpack export
#
# DO NOT use an EVM (0x...) private key here — this is a Solana keypair.
# ⚠️  NEVER share or commit this key.
ORACLE_PRIVATE_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# EPOCH CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────

# Cron schedule for epoch processing (default: every day at midnight UTC)
EPOCH_CRON="0 0 * * *"

# Output directory for proofs.json (relative to oracle/ folder)
# Frontend fetches this file to show claim proofs to users.
PROOFS_OUTPUT_DIR=../frontend/public
