  "author": "Moon Forge Community",
  "license": "MIT",
  "dependencies": {
    "@solana/web3.js": "^1.98.4",
    "dotenv": "^16.3.1",
    "ethers": "^6.9.0",
    "keccak256": "^1.0.6",
    "merkletreejs": "^0.3.11",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/node-cron": "^3.0.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
