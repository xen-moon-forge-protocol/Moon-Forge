{
  "name": "moonforge-oracle",
  "version": "1.0.0",
  "description": "Off-chain oracle for Moon Forge Protocol - bridges EVM burns to X1 rewards",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "epoch": "ts-node src/index.ts --run-epoch",
    "listen": "ts-node src/index.ts --listen"
  },
  "keywords": [
    "xen",
    "x1",
    "oracle",
    "merkle",
    "burn"
