# ─────────────────────────────────────────────────────────────────────────────
#  Moon Forge Protocol — .gitignore
#  NEVER commit secrets, keys, or node_modules to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── SECRETS (NEVER COMMIT) ───────────────────────────────────────────────────
.planning/
.env
.env.local
.env.*.local
*.key
*.pem
keypair.json
*-keypair.json

# ── DEPENDENCIES ─────────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/
oracle/node_modules/

# ── BUILD OUTPUT ─────────────────────────────────────────────────────────────
dist/
build/
frontend/dist/
oracle/dist/
artifacts/
cache/
typechain-types/

# ── HARDHAT ──────────────────────────────────────────────────────────────────
cache/
artifacts/

# ── RUST / ANCHOR BUILD ──────────────────────────────────────────────────────
target/
.anchor/
test-ledger/
# Keypair generated by `anchor build` — contains program private key
# NEVER commit: anyone who has it can upgrade/close the program
programs/moon-forge-games/target/
# Deployer keypair (if accidentally placed here)
deploy-wallet.json

# ── INTERNAL SCRIPTS (one-time deploy helpers — not for community) ───────────
scripts/init-simple.js
scripts/initialize_protocol.ts
.deployment.json

# ── ORACLE STATE ─────────────────────────────────────────────────────────────
oracle/data/state.json
oracle/data/proofs*.json
# Generated by oracle each epoch — served via frontend/public, not committed
frontend/public/proofs.json

# ── LOGS ─────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
