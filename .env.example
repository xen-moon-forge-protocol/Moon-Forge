# ─────────────────────────────────────────────────────────────────────────────
#  Moon Forge Protocol — Environment Variables Template
#
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
#
#  NEVER commit .env to git — it is protected by .gitignore.
#  This file (.env.example) IS committed and safe to share.
# ─────────────────────────────────────────────────────────────────────────────

# ── EVM DEPLOYER ──────────────────────────────────────────────────────────────
# Private key of the deployer wallet. Pays gas only — has zero protocol power
# after renounceOwnership() is called.
#
# IMPORTANT: Use a dedicated fresh wallet. Never use your main personal wallet.
# Fund it by withdrawing from an exchange directly to this address.
# Generate: cast wallet new  (foundry)  OR  any wallet app → export private key
PRIVATE_KEY=0x_your_deployer_private_key_here

# ── DEV SPLITTER RECIPIENTS ───────────────────────────────────────────────────
# These addresses receive the 2% dev fee from early-exit penalties.
# They are set ONCE at deploy and are IMMUTABLE after renounceOwnership().
# Shares are in BPS (basis points): 10000 = 100%. Must sum to 10000.
#
# To use a single wallet: set all three to the same address with shares 10000/0/0
DEV_WALLET_0=0x_dev_recipient_wallet_1
DEV_WALLET_1=0x_dev_recipient_wallet_2_or_same_as_0
DEV_WALLET_2=0x_dev_recipient_wallet_3_or_same_as_0
DEV_SHARE_0=10000   # 100% to wallet 0
DEV_SHARE_1=0       # 0% to wallet 1
DEV_SHARE_2=0       # 0% to wallet 2

# ── ORACLE WALLET ─────────────────────────────────────────────────────────────
# EVM address of the oracle hot wallet.
# This wallet receives 1% of early-exit penalties as gas reimbursement.
# It is immutable after renounceOwnership().
# Use the PUBLIC address here — never the private key.
ORACLE_WALLET=0x_oracle_public_address

# ── NFT METADATA (fill after IPFS upload) ─────────────────────────────────────
# Set this BEFORE calling MoonArtifacts.initializePool() — the URI locks forever.
# Run: npm run nft:generate && npm run nft:upload:images && npm run nft:upload:metadata
# Then set the returned METADATA_CID here.
NFT_BASE_URI=ipfs://YOUR_METADATA_CID/

# ── PINATA (for NFT metadata upload) ──────────────────────────────────────────
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_API_KEY=your_pinata_secret_api_key

# ── EVM RPC ENDPOINTS ─────────────────────────────────────────────────────────
# Public RPCs are used by default. Override here for reliability.
ETH_RPC=https://eth.llamarpc.com
OP_RPC=https://optimism.llamarpc.com
BSC_RPC=https://bsc-dataseed.binance.org
POLYGON_RPC=https://polygon.llamarpc.com
AVAX_RPC=https://api.avax.network/ext/bc/C/rpc
BASE_RPC=https://mainnet.base.org
PULSE_RPC=https://rpc.pulsechain.com

# ── BLOCK EXPLORER API KEYS (optional — for contract verification) ─────────────
ETHERSCAN_API_KEY=
OPTIMISTIC_ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=
POLYGONSCAN_API_KEY=
SNOWTRACE_API_KEY=
BASESCAN_API_KEY=

# ── TESTNETS ───────────────────────────────────────────────────────────────────
SEPOLIA_RPC=https://rpc.sepolia.org
